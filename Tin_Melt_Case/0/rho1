FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      rho1;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 7500.;

boundaryField
{
    floor
    {
        type            zeroGradient;
    }
    ceiling
    {
        type            zeroGradient;
    }
    left
    {
         type            zeroGradient;
    }

    right
    {
        type            zeroGradient;
    }
